ENVIRONMENT=dev
LOG_LEVEL=INFO

APP_NAME=Zero Hunger API
APP_DESCRIPTION=Food redistribution platform API
APP_VERSION=1.0.0

SECRET_KEY=change-me-general-purpose-secret
ACCESS_SECRET=change-me-access-secret
REFRESH_SECRET=change-me-refresh-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DB_NAME=zerohunger
DB_USER=postgres
DB_PASSWORD=postgres
# Must match DB_PASSWORD (used by Postgres container in docker compose)
POSTGRES_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_TYPE=postgresql+asyncpg

CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Authorization,Content-Type,X-Request-ID

# Mobile Google Sign-In: use the **Web application** OAuth client ID (not Android client ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback
FRONTEND_REDIRECT_URL=http://localhost:8080/auth/google/callback

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

RATE_LIMIT_ENABLED=false

# Push (Firebase Cloud Messaging)
FCM_ENABLED=false
# Path to Firebase service account JSON (Project settings → Service accounts → Generate key)
FIREBASE_CREDENTIALS_PATH=

DEFAULT_SEARCH_RADIUS_KM=5
MAX_SEARCH_RADIUS_KM=50
